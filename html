<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MBH HUB</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@900&family=Share+Tech+Mono&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #000;
            overflow: hidden;
            position: relative;
            color: transparent;
            font-size: 0;
        }

        /* ===== FOND ROUGE SOMBRE ===== */
        .bg-glow {
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse at 30% 40%, rgba(180,0,0,0.18) 0%, transparent 55%),
                radial-gradient(ellipse at 70% 60%, rgba(120,0,0,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(60,0,0,0.3) 0%, transparent 80%);
            z-index: 1;
            animation: bgPulse 5s ease-in-out infinite alternate;
        }
        @keyframes bgPulse {
            0%   { opacity: 0.7; }
            100% { opacity: 1; }
        }

        /* ===== CANVAS PARTICULES ===== */
        #fx-canvas {
            position: absolute;
            inset: 0; width: 100%; height: 100%;
            z-index: 2; pointer-events: none;
        }

        /* ===== LIGNES DE SCAN ===== */
        .scanlines {
            position: absolute; inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 3px,
                rgba(0,0,0,0.08) 3px,
                rgba(0,0,0,0.08) 4px
            );
            z-index: 3; pointer-events: none;
        }

        /* ===== PANNEAU PRINCIPAL ===== */
        .central-box {
            width: 22cm;
            height: 5.5cm;
            background: linear-gradient(160deg, rgba(25,0,0,0.97) 0%, rgba(10,0,0,0.99) 100%);
            border-radius: 8px;
            border: 1px solid rgba(200,0,0,0.5);
            box-shadow:
                0 0 0 1px rgba(80,0,0,0.4),
                0 0 25px 8px rgba(200,0,0,0.2),
                0 0 80px 20px rgba(150,0,0,0.1),
                inset 0 0 40px rgba(100,0,0,0.08);
            z-index: 10;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 12px;
        }

        /* Coins décoratifs */
        .central-box::before,
        .central-box::after {
            content: '';
            position: absolute;
            width: 18px; height: 18px;
            border-color: rgba(220,0,0,0.8);
            border-style: solid;
        }
        .central-box::before {
            top: 6px; left: 6px;
            border-width: 2px 0 0 2px;
        }
        .central-box::after {
            bottom: 6px; right: 6px;
            border-width: 0 2px 2px 0;
        }

        /* ===== NOM MBH HUB ANIMÉ ===== */
        .hub-title {
            font-family: 'Cinzel Decorative', 'Arial Black', serif;
            font-size: 2rem;
            font-weight: 900;
            letter-spacing: 8px;
            text-transform: uppercase;
            position: relative;
            z-index: 5;
            color: transparent;
            -webkit-text-fill-color: transparent;
            background: linear-gradient(90deg,
                #ff0000 0%,
                #ff4444 20%,
                #ffffff 35%,
                #ff2222 50%,
                #cc0000 65%,
                #ff6666 80%,
                #ff0000 100%
            );
            background-size: 250% auto;
            -webkit-background-clip: text;
            background-clip: text;
            animation:
                titleFlow 2.5s linear infinite,
                titleShake 6s ease-in-out infinite;
            filter: drop-shadow(0 0 12px rgba(255,0,0,0.9)) drop-shadow(0 0 30px rgba(200,0,0,0.5));
        }

        @keyframes titleFlow {
            0%   { background-position: 0% center; }
            100% { background-position: 250% center; }
        }

        @keyframes titleShake {
            0%,100% { transform: translate(0,0) rotate(0deg) scale(1); }
            10%      { transform: translate(-3px, 1px) rotate(-0.5deg) scale(1.01); }
            20%      { transform: translate(3px, -1px) rotate(0.5deg) scale(0.99); }
            30%      { transform: translate(-2px, 2px) rotate(0deg) scale(1.02); }
            40%      { transform: translate(2px, -1px) rotate(-0.3deg) scale(1); }
            50%      { transform: translate(0, 0) scale(1.03); }
            60%      { transform: translate(-1px, 1px) rotate(0.3deg); }
            70%      { transform: translate(4px, 0) rotate(-0.5deg) scale(0.98); }
            80%      { transform: translate(-2px, -2px) rotate(0.2deg); }
            90%      { transform: translate(1px, 2px); }
        }

        /* Effet glitch sur le titre */
        .hub-title .glitch-layer {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            font-family: inherit;
            font-size: inherit;
            font-weight: inherit;
            letter-spacing: inherit;
            -webkit-text-fill-color: transparent;
            background: inherit;
            -webkit-background-clip: text;
            background-clip: text;
        }
        .hub-title .glitch-layer-1 {
            animation: glitch1 4s infinite;
            color: #ff0000;
            -webkit-text-fill-color: rgba(255,0,0,0.4);
            background: none;
        }
        .hub-title .glitch-layer-2 {
            animation: glitch2 4s infinite;
            color: #ffffff;
            -webkit-text-fill-color: rgba(255,255,255,0.2);
            background: none;
        }

        @keyframes glitch1 {
            0%,90%,100% { transform: none; opacity: 0; }
            91% { transform: translate(-4px, 0) skewX(-5deg); opacity: 1; clip-path: polygon(0 20%, 100% 20%, 100% 40%, 0 40%); }
            93% { transform: translate(4px, 0) skewX(5deg); opacity: 1; }
            95% { opacity: 0; }
        }
        @keyframes glitch2 {
            0%,85%,100% { transform: none; opacity: 0; }
            86% { transform: translate(3px, 0); opacity: 1; clip-path: polygon(0 60%, 100% 60%, 100% 80%, 0 80%); }
            88% { transform: translate(-3px, 0); }
            90% { opacity: 0; }
        }

        /* ===== LIGNE DECO ===== */
        .deco-line {
            width: 80%; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(200,0,0,0.8), rgba(255,60,60,1), rgba(200,0,0,0.8), transparent);
            position: relative;
            animation: linePulse 2s ease-in-out infinite alternate;
        }
        @keyframes linePulse {
            0%   { box-shadow: 0 0 4px rgba(255,0,0,0.4); }
            100% { box-shadow: 0 0 12px rgba(255,0,0,0.9), 0 0 25px rgba(200,0,0,0.4); }
        }

        /* ===== CONTENEUR SCRIPT ===== */
        .script-container {
            width: 88%;
            background: rgba(15,0,0,0.9);
            border: 1px solid rgba(180,0,0,0.4);
            border-radius: 4px;
            padding: 8px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
        }
        .script-container::before {
            content: '> ';
            color: rgba(200,0,0,0.7);
            font-family: 'Share Tech Mono', monospace;
            font-size: 13px;
        }

        .script-text {
            font-family: 'Share Tech Mono', monospace;
            font-size: 12px;
            color: rgba(255,120,120,0.9);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex-grow: 1;
            margin: 0 12px;
            user-select: all;
            animation: textFlicker 8s infinite;
        }
        @keyframes textFlicker {
            0%,98%,100% { opacity: 1; }
            99% { opacity: 0.6; }
        }

        .copy-btn {
            width: 28px; height: 28px;
            background: rgba(150,0,0,0.6);
            border: 1px solid rgba(220,0,0,0.7);
            border-radius: 3px;
            cursor: pointer;
            flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s ease;
            color: #ff4444;
            font-size: 14px;
        }
        .copy-btn:hover {
            background: rgba(220,0,0,0.7);
            box-shadow: 0 0 10px rgba(255,0,0,0.6);
            color: #fff;
        }
        .copy-btn:active {
            transform: scale(0.9);
        }

        /* Petit message "copié" */
        .copied-msg {
            position: absolute;
            top: -28px; right: 0;
            background: rgba(180,0,0,0.9);
            color: #fff;
            font-family: 'Share Tech Mono', monospace;
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 3px;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .copied-msg.show { opacity: 1; }
    </style>
</head>
<body>

    <div class="bg-glow"></div>
    <canvas id="fx-canvas"></canvas>
    <div class="scanlines"></div>

    <div class="central-box">

        <div class="hub-title">
            MBH HUB
            <span class="glitch-layer glitch-layer-1">MBH HUB</span>
            <span class="glitch-layer glitch-layer-2">MBH HUB</span>
        </div>

        <div class="deco-line"></div>

        <div class="script-container">
            <span class="script-text" id="lua-script">Chargement...</span>
            <div class="copied-msg" id="copied-msg">COPIÉ ✓</div>
            <button class="copy-btn" id="copy-btn" title="Copier">⧉</button>
        </div>

    </div>

    <script>
        // ===== PARTICULES BRAISES =====
        (function() {
            const canvas = document.getElementById('fx-canvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let W, H;

            function resize() {
                W = canvas.width  = window.innerWidth;
                H = canvas.height = window.innerHeight;
            }

            function spawnParticle() {
                particles.push({
                    x: Math.random() * W,
                    y: H + 5,
                    vx: (Math.random() - 0.5) * 0.8,
                    vy: -(Math.random() * 1.2 + 0.4),
                    r: Math.random() * 2 + 0.5,
                    alpha: Math.random() * 0.6 + 0.4,
                    life: 1,
                    decay: Math.random() * 0.005 + 0.002,
                    hue: Math.floor(Math.random() * 30)
                });
            }

            function draw() {
                ctx.clearRect(0, 0, W, H);

                // Spawn braises
                for (let i = 0; i < 3; i++) spawnParticle();

                particles = particles.filter(p => p.life > 0);
                for (const p of particles) {
                    p.x += p.vx + Math.sin(p.life * 5) * 0.3;
                    p.y += p.vy;
                    p.life -= p.decay;
                    p.vx *= 0.99;
                    const a = p.life * p.alpha;
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                    ctx.fillStyle = `hsla(${p.hue}, 100%, 60%, ${a})`;
                    ctx.fill();

                    // Halo
                    const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 3);
                    grad.addColorStop(0, `hsla(${p.hue}, 100%, 60%, ${a * 0.3})`);
                    grad.addColorStop(1, 'transparent');
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
                    ctx.fillStyle = grad;
                    ctx.fill();
                }

                requestAnimationFrame(draw);
            }

            resize();
            draw();
            window.addEventListener('resize', resize);
        })();

        // ===== SCRIPT LUA =====
        document.addEventListener("DOMContentLoaded", function() {
            const scriptEl = document.getElementById("lua-script");
            const copyBtn  = document.getElementById("copy-btn");
            const copiedMsg = document.getElementById("copied-msg");
            const currentUrl = window.location.href;
            const luaCode = `loadstring(game:HttpGet('${currentUrl}'))()`;
            scriptEl.textContent = luaCode;

            copyBtn.addEventListener("click", function() {
                navigator.clipboard.writeText(luaCode).then(function() {
                    copiedMsg.classList.add('show');
                    setTimeout(() => copiedMsg.classList.remove('show'), 1800);
                }).catch(function(err) {
                    alert("Erreur lors de la copie.");
                });
            });
        });
    </script>

</body>
</html>

